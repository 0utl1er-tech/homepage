# =============================================================================
# 0UTL1ER homepage — 環境変数サンプル
# ローカルは `.env.local` にコピーして使用。
# 本番(CI)は Forgejo → リポジトリ → Actions → Variables に設定すると
# .forgejo/workflows/build.yml の build-args 経由でイメージに焼き込まれる。
# NEXT_PUBLIC_* は browser bundle に焼き込まれる public な値（secret ではない）。
# =============================================================================

# ---- Strapi CMS（未設定ならサンプル表示） ----------------------------------
NEXT_PUBLIC_STRAPI_URL=https://cms.0utl1er.tech   # 末尾の /api は不要
STRAPI_TOKEN=                                       # Public 公開なら空でOK（server 専用 / runtime env）

# ---- 計測タグ（未設定なら出力されない = 安全） -----------------------------
# Google タグマネージャー コンテナ ID
NEXT_PUBLIC_GTM_ID=                                 # 例: GTM-XXXXXXX
# GA4 測定 ID（GTM 経由で入れる場合は空のままでよい。両方入れると二重計測）
NEXT_PUBLIC_GA_ID=                                  # 例: G-XXXXXXXXXX
# Ahrefs Web Analytics（無料）の data-key（UUID）
NEXT_PUBLIC_AHREFS_KEY=

# ---- サイト所有権の確認用 meta タグ（未設定なら出力されない） --------------
# Google Search Console の HTML タグ確認（content 値のみ）
NEXT_PUBLIC_SITE_VERIFICATION_GOOGLE=
# Ahrefs Webmaster Tools（サイト検証 / 無料）
NEXT_PUBLIC_SITE_VERIFICATION_AHREFS=
# Bing Webmaster Tools（任意）
NEXT_PUBLIC_SITE_VERIFICATION_BING=
